{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NeuroFace Helm Chart Values",
  "description": "Facial Recognition Webapp with ML - FastAPI backend + Angular frontend on Red Hat UBI9 with OpenVINO Model Server",
  "type": "object",
  "properties": {
    "backend": {
      "type": "object",
      "title": "Backend",
      "description": "FastAPI backend configuration",
      "properties": {
        "image": {
          "type": "object",
          "title": "Container Image",
          "properties": {
            "repository": {
              "type": "string",
              "title": "Image Repository",
              "description": "Backend container image repository",
              "default": "quay.io/maximilianopizarro/neuroface-backend"
            },
            "tag": {
              "type": "string",
              "title": "Image Tag",
              "description": "Backend container image tag",
              "default": "v1.2.0"
            },
            "pullPolicy": {
              "type": "string",
              "title": "Image Pull Policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "Always"
            }
          }
        },
        "replicas": {
          "type": "integer",
          "title": "Replicas",
          "description": "Number of backend pod replicas",
          "minimum": 1,
          "default": 1
        },
        "port": {
          "type": "integer",
          "title": "Port",
          "description": "Backend container port",
          "default": 8080
        },
        "resources": {
          "type": "object",
          "title": "Resources",
          "description": "CPU and memory resource limits/requests",
          "properties": {
            "limits": {
              "type": "object",
              "title": "Limits",
              "properties": {
                "cpu": {
                  "type": "string",
                  "title": "CPU Limit",
                  "default": "500m"
                },
                "memory": {
                  "type": "string",
                  "title": "Memory Limit",
                  "default": "512Mi"
                }
              }
            },
            "requests": {
              "type": "object",
              "title": "Requests",
              "properties": {
                "cpu": {
                  "type": "string",
                  "title": "CPU Request",
                  "default": "100m"
                },
                "memory": {
                  "type": "string",
                  "title": "Memory Request",
                  "default": "256Mi"
                }
              }
            }
          }
        },
        "aiModel": {
          "type": "string",
          "title": "AI Model",
          "description": "Face recognition model to use",
          "enum": ["lbph", "dlib"],
          "default": "lbph"
        },
        "dlibEnabled": {
          "type": "boolean",
          "title": "Enable dlib",
          "description": "Allow dlib face recognition model (requires face_recognition package in image)",
          "default": false
        }
      }
    },
    "frontend": {
      "type": "object",
      "title": "Frontend",
      "description": "Angular frontend configuration",
      "properties": {
        "image": {
          "type": "object",
          "title": "Container Image",
          "properties": {
            "repository": {
              "type": "string",
              "title": "Image Repository",
              "description": "Frontend container image repository",
              "default": "quay.io/maximilianopizarro/neuroface-frontend"
            },
            "tag": {
              "type": "string",
              "title": "Image Tag",
              "description": "Frontend container image tag",
              "default": "v1.2.0"
            },
            "pullPolicy": {
              "type": "string",
              "title": "Image Pull Policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "Always"
            }
          }
        },
        "replicas": {
          "type": "integer",
          "title": "Replicas",
          "description": "Number of frontend pod replicas",
          "minimum": 1,
          "default": 1
        },
        "port": {
          "type": "integer",
          "title": "Port",
          "description": "Frontend container port",
          "default": 8080
        },
        "resources": {
          "type": "object",
          "title": "Resources",
          "description": "CPU and memory resource limits/requests",
          "properties": {
            "limits": {
              "type": "object",
              "title": "Limits",
              "properties": {
                "cpu": {
                  "type": "string",
                  "title": "CPU Limit",
                  "default": "200m"
                },
                "memory": {
                  "type": "string",
                  "title": "Memory Limit",
                  "default": "256Mi"
                }
              }
            },
            "requests": {
              "type": "object",
              "title": "Requests",
              "properties": {
                "cpu": {
                  "type": "string",
                  "title": "CPU Request",
                  "default": "50m"
                },
                "memory": {
                  "type": "string",
                  "title": "Memory Request",
                  "default": "128Mi"
                }
              }
            }
          }
        }
      }
    },
    "chat": {
      "type": "object",
      "title": "AI Chat",
      "description": "Optional AI chat feature powered by KServe/HuggingFace LLM endpoints",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable AI Chat",
          "description": "Enable the AI facial analysis chat feature",
          "default": false
        },
        "modelEndpoint": {
          "type": "string",
          "title": "Model Endpoint",
          "description": "LLM inference endpoint URL (OpenAI-compatible). Example: https://isvc-granite-31-8b-fp8-predictor.sandbox-shared-models.svc.cluster.local:8443",
          "default": ""
        },
        "modelName": {
          "type": "string",
          "title": "Model Name",
          "description": "Model identifier sent in the API request (e.g. granite-31-8b-fp8)",
          "default": ""
        },
        "apiKey": {
          "type": "string",
          "title": "API Key",
          "description": "Bearer token for the LLM endpoint (ignored when autoServiceAccount is enabled)",
          "default": ""
        },
        "autoServiceAccount": {
          "type": "boolean",
          "title": "Auto Service Account",
          "description": "Create a ServiceAccount and inject its token for KServe OAuth authentication automatically",
          "default": true
        },
        "maxTokens": {
          "type": "integer",
          "title": "Max Tokens",
          "description": "Maximum tokens in the LLM response",
          "minimum": 64,
          "maximum": 4096,
          "default": 512
        },
        "systemPrompt": {
          "type": "string",
          "title": "System Prompt",
          "description": "System prompt for the facial analysis assistant",
          "default": "You are a facial analysis assistant. Analyze the provided facial detection data and answer questions about expressions, characteristics, and features of the detected faces. Be concise and informative."
        }
      }
    },
    "ovms": {
      "type": "object",
      "title": "OpenVINO Model Server",
      "description": "Deploy OpenVINO Model Server v2025.2.1 for optimized AI inference. Accessible within the cluster without token.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable OVMS",
          "description": "Enable OpenVINO Model Server for face detection",
          "default": true
        },
        "externalUrl": {
          "type": "string",
          "title": "External OVMS URL",
          "description": "URL of an external OVMS/ModelMesh REST endpoint (e.g. http://modelmesh-serving:8008). When set, no standalone OVMS is deployed.",
          "default": ""
        },
        "image": {
          "type": "object",
          "title": "Container Image",
          "properties": {
            "repository": {
              "type": "string",
              "title": "Image Repository",
              "default": "openvino/model_server"
            },
            "tag": {
              "type": "string",
              "title": "Image Tag",
              "default": "2025.2.1"
            },
            "pullPolicy": {
              "type": "string",
              "title": "Image Pull Policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "replicas": {
          "type": "integer",
          "title": "Replicas",
          "minimum": 1,
          "default": 1
        },
        "restPort": {
          "type": "integer",
          "title": "REST API Port",
          "default": 8000
        },
        "grpcPort": {
          "type": "integer",
          "title": "gRPC Port",
          "default": 9000
        },
        "resources": {
          "type": "object",
          "title": "Resources",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "200m" },
                "memory": { "type": "string", "default": "512Mi" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "2" },
                "memory": { "type": "string", "default": "4Gi" }
              }
            }
          }
        },
        "route": {
          "type": "object",
          "title": "OpenShift Route",
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "Enable Route",
              "default": true
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string",
                  "enum": ["edge", "passthrough", "reencrypt"],
                  "default": "edge"
                }
              }
            }
          }
        },
        "modelName": {
          "type": "string",
          "title": "Face Detection Model Name",
          "description": "Name of the face detection model deployed on OVMS / ModelMesh",
          "default": "face-detection-retail-0005"
        },
        "confidenceThreshold": {
          "type": "string",
          "title": "Detection Confidence Threshold",
          "description": "Minimum confidence score (0.0-1.0) for face detections from the OpenVINO model",
          "default": "0.5"
        },
        "defaultDetectionMethod": {
          "type": "string",
          "title": "Default Detection Method",
          "description": "Initial face detection method: opencv (local Haar cascades) or openvino (remote OVMS)",
          "enum": ["opencv", "openvino"],
          "default": "opencv"
        },
        "models": {
          "type": "array",
          "title": "Model Configurations",
          "description": "List of models to serve (used to generate config.json). Leave empty for model repository auto-discovery.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "title": "Model Name" },
              "path": { "type": "string", "title": "Model Path" },
              "layout": { "type": "string", "title": "Layout (e.g. NCHW:NHWC)" }
            },
            "required": ["name", "path"]
          },
          "default": []
        }
      }
    },
    "litellm": {
      "type": "object",
      "title": "LiteLLM Proxy",
      "description": "Optional LiteLLM proxy for OpenAI-compatible API with tool calling support (Developer Sandbox pattern)",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable LiteLLM",
          "description": "Deploy LiteLLM proxy for unified LLM access",
          "default": false
        },
        "image": {
          "type": "object",
          "title": "Container Image",
          "properties": {
            "repository": {
              "type": "string",
              "default": "litellm/litellm-non_root"
            },
            "tag": {
              "type": "string",
              "default": "v1.82.3-stable"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "default": 4000
            }
          }
        },
        "route": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string",
                  "enum": ["edge", "passthrough", "reencrypt"],
                  "default": "edge"
                }
              }
            }
          }
        },
        "masterKey": {
          "type": "string",
          "title": "Master Key",
          "description": "Bearer token for the LiteLLM proxy API",
          "default": "sk-neuroface-1234"
        },
        "model": {
          "type": "object",
          "title": "LLM Model Configuration",
          "properties": {
            "name": {
              "type": "string",
              "title": "Model Alias",
              "description": "Friendly name exposed via the API",
              "default": "qwen3"
            },
            "modelId": {
              "type": "string",
              "title": "Model ID",
              "description": "Actual model identifier at the inference endpoint",
              "default": "isvc-qwen3-8b-fp8"
            },
            "apiBase": {
              "type": "string",
              "title": "API Base URL",
              "description": "vLLM/RHOAI inference endpoint base URL",
              "default": "https://isvc-qwen3-8b-fp8-predictor.sandbox-shared-models.svc.cluster.local:8443/v1"
            },
            "apiKey": {
              "type": "string",
              "title": "API Key",
              "description": "OAuth token for the model endpoint (refresh with: oc whoami -t)",
              "default": ""
            }
          }
        },
        "resources": {
          "type": "object",
          "title": "Resources",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "200m" },
                "memory": { "type": "string", "default": "512Mi" }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": "string", "default": "1" },
                "memory": { "type": "string", "default": "2Gi" }
              }
            }
          }
        }
      }
    },
    "route": {
      "type": "object",
      "title": "OpenShift Route",
      "description": "Expose the application via an OpenShift Route",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable Route",
          "description": "Create an OpenShift Route for external access",
          "default": true
        },
        "host": {
          "type": "string",
          "title": "Hostname",
          "description": "Custom hostname for the route (leave empty for auto-generated)",
          "default": ""
        },
        "tls": {
          "type": "object",
          "title": "TLS",
          "properties": {
            "termination": {
              "type": "string",
              "title": "TLS Termination",
              "enum": ["edge", "passthrough", "reencrypt"],
              "default": "edge"
            }
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "title": "Persistence",
      "description": "Persistent storage for training data and models",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable Persistence",
          "description": "Use a PersistentVolumeClaim for data storage",
          "default": true
        },
        "size": {
          "type": "string",
          "title": "Volume Size",
          "description": "Size of the persistent volume",
          "default": "1Gi"
        },
        "storageClassName": {
          "type": "string",
          "title": "Storage Class",
          "description": "StorageClass name (leave empty for cluster default)",
          "default": ""
        },
        "accessModes": {
          "type": "array",
          "title": "Access Modes",
          "items": {
            "type": "string",
            "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"]
          },
          "default": ["ReadWriteOnce"]
        }
      }
    }
  }
}
